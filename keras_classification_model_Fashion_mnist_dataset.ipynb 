      "source": [
        "###Define CNN Model\n",
        "\n",
        "input=keras.Input(shape=x_train.shape[1:]) ## 28,28,1\n",
        "\n",
        "##convolutional layer\n",
        "\n",
        "x=keras.layers.Conv2D(filters=32,kernel_size=(2,2),\n",
        "                      activation='relu',name=\"Conv1\")(input) ## numb of filters,size of filter is 2,2 and activationis relu\n",
        "\n",
        "##pooling layer\n",
        "\n",
        "x=keras.layers.MaxPool2D(pool_size=(2,2),name=\"pool1\")(x)\n",
        "\n",
        "## end of first CNN block\n",
        "\n",
        "### second conv block\n",
        "x=keras.layers.Conv2D(filters=64,kernel_size=(2,2),activation='relu',name=\"Conv2\")(x)\n",
        "x=keras.layers.MaxPool2D(pool_size=(2,2),name=\"pool2\")(x)\n",
        "\n",
        "##flattern layer\n",
        "\n",
        "x=keras.layers.Flatten()(x)\n",
        "###fully connected Dense Relu layer\n",
        "x=keras.layers.Dense(256,activation='relu')(x)\n",
        "\n",
        "##output dense layer\n",
        "\n",
        "output=keras.layers.Dense(10,activation='softmax')(x)\n",
        "\n",
        "model=keras.Model(inputs=input,outputs=output)"
